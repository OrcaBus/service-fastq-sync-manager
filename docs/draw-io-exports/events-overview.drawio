              <mxPoint x="485" y="540"/>
              <mxPoint x="610" y="540"/>
              <mxPoint x="610" y="489"/>
            </Array>
          </mxGeometry>
        </mxCell>

        <!-- Fastq ID Updated → External SFN (sendTaskSuccess) -->
        <mxCell id="e13" value="sendTaskSuccess" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#82b366;strokeWidth=2;fontSize=10;fontColor=#888888;fontStyle=2;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=0.5;entryY=1;entryDx=0;entryDy=0;" edge="1" source="n11" target="n1" parent="1">
          <mxGeometry relative="1" as="geometry">
