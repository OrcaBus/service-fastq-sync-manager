<mxfile host="app.diagrams.net">
  <diagram name="external-heartbeat-monitor" id="external-heartbeat-monitor">
    <mxGraphModel dx="1200" dy="1000" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- ═══════════════ COLUMN A (x=25) ═══════════════ -->

        <!-- Start oval -->
        <mxCell id="n1" value="Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1a1a1a;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="147" y="30" width="56" height="36" as="geometry"/>
        </mxCell>

        <!-- Decision: Has tokens? -->
        <mxCell id="n2" value="Has active&#xa;task tokens?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="55" y="110" width="240" height="62" as="geometry"/>
        </mxCell>

        <!-- Side-float: Disable scheduler -->
        <mxCell id="n3" value="&lt;b&gt;Disable heartbeat scheduler&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="400" y="118" width="240" height="46" as="geometry"/>
        </mxCell>

        <!-- Step: For each token (batched) -->
        <mxCell id="n4" value="&lt;b&gt;For each task token (batched)&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:11px;color:#555555;&quot;&gt;distributed map with pagination&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="25" y="220" width="300" height="62" as="geometry"/>
        </mxCell>

        <!-- Step: Check running jobs -->
        <mxCell id="n5" value="&lt;b&gt;Check running jobs for fastq list&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:11px;color:#555555;&quot;&gt;query APIs for active jobs&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="25" y="330" width="300" height="62" as="geometry"/>
        </mxCell>

        <!-- Decision: Jobs running? -->
        <mxCell id="n6" value="Jobs running?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="55" y="440" width="240" height="62" as="geometry"/>
        </mxCell>

        <!-- Side-float: Send heartbeat -->
        <mxCell id="n7" value="&lt;b&gt;Send heartbeat&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:11px;color:#555555;&quot;&gt;keep token alive&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="400" y="440" width="240" height="62" as="geometry"/>
        </mxCell>

        <!-- Step: Check requirements -->
        <mxCell id="n8" value="&lt;b&gt;Check requirements for token&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:11px;color:#555555;&quot;&gt;verify fastq IDs meet conditions&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="25" y="550" width="300" height="62" as="geometry"/>
        </mxCell>

        <!-- Decision: All satisfied? -->
        <mxCell id="n9" value="All requirements&#xa;satisfied?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="55" y="660" width="240" height="62" as="geometry"/>
        </mxCell>

        <!-- Side-float: Send task success + clean up -->
        <mxCell id="n10" value="&lt;b&gt;Send task success + clean up&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:11px;color:#555555;&quot;&gt;release token + delete DB entries&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="400" y="660" width="240" height="62" as="geometry"/>
        </mxCell>

        <!-- Terminal: Success -->
        <mxCell id="n11" value="Success" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;arcSize=50;" vertex="1" parent="1">
          <mxGeometry x="75" y="770" width="200" height="46" as="geometry"/>
        </mxCell>

        <!-- Edge: Start → Has tokens? -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n1" target="n2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edge: Has tokens? → Disable scheduler (no) -->
        <mxCell id="e2" value="no" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#888888;strokeWidth=2;dashed=1;dashPattern=8 4;fontSize=10;fontColor=#888888;fontStyle=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="n2" target="n3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edge: Has tokens? → For each token (yes) -->
        <mxCell id="e3" value="yes" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;fontSize=10;fontColor=#888888;fontStyle=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n2" target="n4" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edge: For each token → Check running jobs -->
        <mxCell id="e4" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n4" target="n5" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edge: Check running jobs → Jobs running? -->
        <mxCell id="e5" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n5" target="n6" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edge: Jobs running? → Send heartbeat (yes) -->
        <mxCell id="e6" value="yes" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;fontSize=10;fontColor=#888888;fontStyle=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="n6" target="n7" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edge: Jobs running? → Check requirements (no) -->
        <mxCell id="e7" value="no" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;fontSize=10;fontColor=#888888;fontStyle=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n6" target="n8" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edge: Check requirements → All satisfied? -->
        <mxCell id="e8" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n8" target="n9" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edge: All satisfied? → Send success (yes) -->
        <mxCell id="e9" value="yes" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;fontSize=10;fontColor=#888888;fontStyle=2;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" source="n9" target="n10" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edge: All satisfied? → Success (no — may timeout) -->
        <mxCell id="e10" value="no" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#888888;strokeWidth=2;dashed=1;dashPattern=8 4;fontSize=10;fontColor=#888888;fontStyle=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n9" target="n11" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
