<mxfile host="app.diagrams.net">
  <diagram name="send-fastq-sync-request-to-queue" id="send-fastq-sync-request-to-queue">
    <mxGraphModel dx="800" dy="400" grid="0" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="0" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Start oval -->
        <mxCell id="n1" value="Start" style="ellipse;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1a1a1a;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="147" y="30" width="56" height="36" as="geometry"/>
        </mxCell>

        <!-- Step: Send message to SQS queue -->
        <mxCell id="n2" value="&lt;b&gt;Send message to SQS queue&lt;/b&gt;&lt;br&gt;&lt;i style=&quot;font-size:11px;color:#555555;&quot;&gt;throttle sync requests via queue&lt;/i&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;strokeWidth=2;fontSize=13;fontColor=#1a1a1a;" vertex="1" parent="1">
          <mxGeometry x="25" y="110" width="300" height="62" as="geometry"/>
        </mxCell>

        <!-- Terminal: Success -->
        <mxCell id="n3" value="Success" style="ellipse;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;strokeWidth=2;fontSize=13;fontStyle=1;fontColor=#1a1a1a;arcSize=50;" vertex="1" parent="1">
          <mxGeometry x="75" y="220" width="200" height="46" as="geometry"/>
        </mxCell>

        <!-- Edge: Start → Send message -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n1" target="n2" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edge: Send message → Success -->
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;strokeColor=#555555;strokeWidth=2;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=0.5;entryY=0;entryDx=0;entryDy=0;" edge="1" source="n2" target="n3" parent="1">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
