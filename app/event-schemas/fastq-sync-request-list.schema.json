{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "fastq sync request",
  "type": "object",
  "properties": {
    "EventBusName": {
      "type": "string"
    },
    "Source": {
      "type": "string"
    },
    "DetailType": {
      "type": "string"
    },
    "Detail": {
      "type": "object",
      "properties": {
        "taskToken": {
          "type": "string"
        },
        "payload": {
          "type": "object",
          "properties": {
            "fastqIdList": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "requirements": {
              "type": "object",
              "properties": {
                "hasActiveReadSet": {
                  "oneOf": [
                    { "type": "boolean" },
                    {
                      "type": "object",
                      "properties": {
                        "bucket": { "type": "string", "minLength": 1, "maxLength": 63 },
                        "prefix": { "type": "string", "minLength": 1, "maxLength": 1024 }
                      },
                      "required": ["bucket", "prefix"],
                      "additionalProperties": false
                    }
                  ]
                },
                "hasQc": {
                  "type": "boolean"
                },
                "hasFingerprint": {
                  "type": "boolean"
                },
                "hasFileCompressionInformation": {
                  "type": "boolean"
                },
                "hasReadCount": {
                  "type": "boolean"
                }
              },
              "required": []
            },
            "forceUnarchiving": {
              "type": "boolean"
            }
          },
          "required": ["requirements", "fastqIdList"]
        }
      },
      "required": ["taskToken", "payload"]
    }
  },
  "required": ["EventBusName", "Source", "DetailType", "Detail"]
}
